<resources>

    <!-- Base application theme. Using Material3 Light for the inverted look -->
    <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
        <!-- Main Palette: Clean Light Monotone -->
        <item name="colorPrimary">@color/brand_charcoal</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/gray_500</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- UI Surfaces -->
        <item name="android:windowBackground">@color/brand_bg_light</item>
        <item name="android:statusBarColor">@color/brand_charcoal</item>
        <item name="android:navigationBarColor">@color/brand_bg_light</item>

        <!-- Surface & Card Colors -->
        <item name="colorSurface">@color/brand_surface_white</item>
        <item name="colorOnSurface">@color/brand_charcoal</item>
        <item name="colorSurfaceVariant">@color/brand_divider</item>
        <item name="colorOnSurfaceVariant">@color/brand_grey_text</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/brand_charcoal</item>
        <item name="android:textColorSecondary">@color/brand_grey_text</item>

        <!-- Status Bar Appearance (White text on dark toolbar) -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Toolbar customization -->
        <item name="toolbarStyle">@style/AppTheme.Toolbar</item>
    </style>

    <style name="AppTheme.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="background">@color/brand_charcoal</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
        <item name="titleTextAppearance">@style/TextAppearance.App.Toolbar.Title</item>
    </style>

    <style name="TextAppearance.App.Toolbar.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- This overlay forces icons/text to be white -->
    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

</resources>
