@startuml
!define COMPONENT(name) component name
!define FRAGMENT(name) component name <<Fragment>>
!define DTO(name) component name <<DTO>>

package "com.mynet.kazekima.wsfighterscard" {
    package "settings" {
        FRAGMENT(SettingsFragment)
        COMPONENT(SettingsViewModel)

        package "models" {
            DTO(AppDataExportDto)
            DTO(FighterExportDto)
            DTO(DeckExportDto)
            DTO(GameExportDto)
            DTO(ScoreExportDto)
        }
    }
}

package "Data Layer" {
    COMPONENT(FightersRepository)
    COMPONENT(FightersDatabase) <<Database>>
}

' --- Dependencies ---

SettingsFragment -down-> SettingsViewModel
SettingsViewModel -down-> FightersRepository
SettingsViewModel .right.> models : "uses for Import/Export"

FightersRepository -down-> FightersDatabase
@enduml
